{
  "mcpServers": [
    {
      "name": "slack",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_USER_ID": "${SLACK_USER_ID}"
      }
    },
    {
      "name": "filesystem",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/opt/data/profile-alfred",
        "/opt/data/profile-shared",
        "/opt/data/cluster-shared"
      ]
    },
    {
      "name": "time",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-time"],
      "env": {
        "DEFAULT_TIMEZONE": "${ALFRED_TIMEZONE}"
      }
    }
  ]
}
